// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/kubernetes-helm
{
	"name": "Kubernetes - Local Configuration",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:bullseye",
	"features": {
		"ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
			"version": "latest",
			"helm": "3",
			"minikube": "none"
		},
		"ghcr.io/wcgomes/devcontainer-features/the-agency:0": {
			"use-agent-zero": true
		}
	},
	"mounts": [
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.kube/config,target=/usr/local/share/kube-localhost/config,type=bind,readonly"
	],
	"postStartCommand": "bash .devcontainer/copy-kube-config.sh"
}