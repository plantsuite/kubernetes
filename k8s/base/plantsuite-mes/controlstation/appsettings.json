{
    "ServiceName": "plantsuite-controlstation",
    "IntegrationCodeRequired": false,
    "Database": {
        "MongoDb": {
            "DatabaseName": "ps-controlstation"
        }
    },
    "JwtOptions": {
        "Audience": "ps-mes-portal",
        "Authority": "https://account.dev.plantsuite.com/realms/plantsuite",
        "RequireHttpsMetadata": true
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://0.0.0.0:80"
            }
        }
    },
    "MessageBus": {
        "RabbitMQ": {
            "Host": "rabbitmq.rabbitmq.svc.cluster.local",
            "Port": 5672,
            "RetryCount": 5,
            "RetryInterval": 5000,
            "VirtualHost": "ps-mes",
            "SetQuorumQueue": true
        },
        "MQTT": {
            "Host": "vernemq.vernemq.svc.cluster.local",
            "Port": 1883
        }
    },
    "Otlp": {
        "Endpoint": "http://otel-collector.monitoring.svc.cluster.local:4317",
        "Metrics": {
            "AddCoreAppMetrics": false,
            "Enabled": false
        },
        "Tracing": {
            "Enabled": false,
            "SamplerProbability": 0.01
        }
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            }
        ]
    }
}