{
    "VirtualHostname": "",
    "Database": {
        "MessageDatabaseName": "ps-messagedata",
        "DatabaseName": "ps-wd"
    },
    "JwtOptions": {
        "Audience": "ps-mes-portal",
        "Authority": "https://account.dev.plantsuite.com/realms/plantsuite",
        "RequireHttpsMetadata": true
    },
    "EventBus": {
        "Host": "rabbitmq.rabbitmq.svc.cluster.local",
        "Port": 5672,
        "RetryCount": 5,
        "RetryInterval": 5000,
        "VirtualHost": "ps-mes",
        "SetQuorumQueue": true
    },
    "MQTT": {
        "Host": "vernemq.vernemq.svc.cluster.local",
        "Port": 1883
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://*:80"
            }
        }
    },
    "Host": {
        "Port": 80
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            }
        ]
    },
    "ElasticApm": {
        "Enabled": false,
        "SecretToken": "",
        "ServerUrls": "http://localhost:8200",
        "ServiceName": "plantsuite-wd"
    }
}