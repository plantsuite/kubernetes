{
    "ServiceName": "plantsuite-alarms",
    "Keycloak": {
        "ApiUrl": "",
        "Realm": "plantsuite",
        "IntrospectionClientId": "ps-auth-introspection",
        "IntrospectionClientSecret": ""
    },
    "BackgroundServices": {
        "RuleMonitor": {
            "Interval": 10000
        }
    },
    "Database": {
        "MongoDb": {
            "CollectionPrefixTag": "alm",
            "ConnectionString": "",
            "HangfireDatabaseName": "ps-hangfire"
        },
        "Redis": {
            "ConnectionString": ""
        }
    },
    "JwtOptions": {
        "Audience": "ps-iot-portal",
        "Authority": "",
        "RequireHttpsMetadata": true
    },
    "MessageBus": {
        "RabbitMQ": {
            "ConnectionString": ""
        }
    },
    "Hangfire": {
        "SchedulePollingInterval": 5
    },
    "Observability": {
        "OtlpEndpoint": "http://dashboard.aspire.svc.cluster.local:4317",
        "Metrics": {
            "Enabled": true
        },
        "Tracing": {
            "Enabled": true,
            "SamplerProbability": 0.01
        },
        "Logging": {
            "Enabled": true
        }
    },
    "Licensing": {
        "LicensePath": "/etc/plantsuite/license.crt",
        "ExpirationWarningDays": 90
    },
    "TenantIds": []
}