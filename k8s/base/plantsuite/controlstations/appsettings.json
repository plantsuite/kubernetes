{
    "ServiceName": "plantsuite-controlstations",
    "IntegrationCodeRequired": false,
    "Database": {
        "MongoDb": {
            "DatabaseName": "ps-controlstations"
        }
    },
    "JwtOptions": {
        "Audience": "ps-iot-portal",
        "Authority": "",
        "RequireHttpsMetadata": true
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://0.0.0.0:80"
            }
        }
    },
    "MessageBus": {
        "RabbitMQ": {
            "Host": "",
            "Port": 5672,
            "RetryCount": 5,
            "RetryInterval": 5000,
            "VirtualHost": "/",
            "SetQuorumQueue": true
        },
        "MQTT": {
            "Host": "",
            "Port": 1883
        }
    },
    "Otlp": {
        "Endpoint": "http://dashboard.aspire.svc.cluster.local:4317",
        "Metrics": {
            "AddCoreAppMetrics": false,
            "Enabled": true
        },
        "Tracing": {
            "Enabled": true,
            "SamplerProbability": 0.01
        }
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            }
        ]
    }
}