{
  "Database": {
    "Sqlite": {
      "Path": "/var/lib/plantsuite/gateway.db"
    }
  },
  "Instance": {
    "Id": "${appsettings_Instance__Id}",
    "Name": "${appsettings_Instance__Name}"
  },
  "Licensing": {
    "ExpirationWarningDays": 90,
    "LicensePath": "/etc/plantsuite/license.crt"
  },
  "LocalAuth": {
    "Password": "${appsettings_LocalAuth__Password}",
    "Username": "${appsettings_LocalAuth__Username}"
  },
  "MessageBus": {
    "MQTT": {
      "Host": "${appsettings_Mqttconfig__Host}",
      "Password": "${appsettings_Mqttconfig__Password}",
      "Port": 1883,
      "User": "${appsettings_Mqttconfig__User}"
    },
    "RabbitMQ": {
      "ConnectionString": "${appsettings_RabbitMQ__ConnectionString}"
    }
  },
  "Observability": {
    "Logging": {
      "Enabled": true
    },
    "Metrics": {
      "Enabled": true
    },
    "OtlpEndpoint": "",
    "Tracing": {
      "Enabled": true,
      "SamplerProbability": 0.1
    }
  },
  "ServiceName": "plantsuite-iot-gateway"
}
