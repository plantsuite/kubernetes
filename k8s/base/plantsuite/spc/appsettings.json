{
    "ServiceName": "plantsuite-spc",
    "Keycloak": {
        "ApiUrl": "",
        "Realm": "plantsuite",
        "IntrospectionClientId": "ps-auth-introspection",
        "IntrospectionClientSecret": ""
    },
    "Database": {
        "MongoDb": {
            "CollectionPrefixTag": "spc",
            "ConnectionString": ""
        }
    },
    "JwtOptions": {
        "Audience": "ps-iot-portal",
        "Authority": "",
        "RequireHttpsMetadata": true
    },
    "MessageBus": {
        "RabbitMQ": {
            "ConnectionString": ""
        }
    },
    "Observability": {
        "OtlpEndpoint": "http://dashboard.aspire.svc.cluster.local:4317",
        "Metrics": {
            "Enabled": true
        },
        "Tracing": {
            "Enabled": true,
            "SamplerProbability": 0.01
        },
        "Logging": {
            "Enabled": true
        }
    },
    "Licensing": {
        "LicensePath": "/etc/plantsuite/license.crt",
        "ExpirationWarningDays": 90
    },
    "BackgroundServices": {
        "ControlChartMonitor": {
            "Interval": 60000
        },
        "ControlChartSummaryMonitor": {
            "Interval": 60000
        }
    }
}