{
    "ServiceName": "plantsuite-timeseries-mqtt",
    "Keycloak": {
        "ApiUrl": "",
        "Realm": "plantsuite",
        "IntrospectionClientId": "ps-auth-introspection",
        "IntrospectionClientSecret": ""
    },
    "Database": {
        "MongoDb": {
            "CollectionPrefixTag": "tms",
            "ConnectionString": ""
        },
        "Redis": {
            "ConnectionString": ""
        }
    },
    "JwtOptions": {
        "Audience": "ps-iot-portal",
        "Authority": "",
        "RequireHttpsMetadata": true
    },
    "MessageBus": {
        "MQTT": {
            "Host": "",
            "Port": 1883,
            "User": "",
            "Password": ""
        },
        "RabbitMQ": {
            "ConnectionString": ""
        }
    },
    "Observability": {
        "OtlpEndpoint": "http://dashboard.aspire.svc.cluster.local:4317",
        "Metrics": {
            "Enabled": true
        },
        "Tracing": {
            "Enabled": true,
            "SamplerProbability": 0.01
        },
        "Logging": {
            "Enabled": true
        }
    },
    "Licensing": {
        "LicensePath": "/etc/plantsuite/license.crt",
        "ExpirationWarningDays": 90
    },
    "Services": {
        "EnableBufferProcessor": false,
        "EnableDataCollector": true
    }
}